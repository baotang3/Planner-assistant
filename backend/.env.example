# ===========================================
# LLM 配置
# ===========================================

# 默认 LLM 提供商: deepseek / aliyun / openai
LLM_PROVIDER=deepseek

# DeepSeek 配置
DEEPSEEK_API_KEY=sk-83ddc61d745f41aa8befc89e07cb2a66
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 阿里云百炼配置
ALIYUN_DASHSCOPE_API_KEY=sk-ac00a05732194d588ca12cd7a71320df
ALIYUN_MODEL=qwen-plus

# OpenAI 配置 (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# ===========================================
# LangSmith 配置 (Agent 可观测性)
# ===========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trip-planner-agent

# ===========================================
# 高德地图 API
# ===========================================
AMAP_API_KEY=eab7b98b381eae56fa2867e403a93c33

# ===========================================
# 向量数据库配置
# ===========================================
CHROMA_PERSIST_DIRECTORY=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# 服务器配置
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# Unsplash API (景点图片)
# ===========================================
UNSPLASH_ACCESS_KEY=your_unsplash_key
